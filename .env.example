# ---------------------------------------------------------------------------
# Content source
# ---------------------------------------------------------------------------
# The site runs on local SEED data by default (no account needed).
# Set this to "sanity" to switch to the Sanity CMS provider once configured.
NEXT_PUBLIC_CONTENT_SOURCE=seed

# ---------------------------------------------------------------------------
# Sanity CMS (only needed when NEXT_PUBLIC_CONTENT_SOURCE=sanity)
# Create a free project at https://sanity.io/manage
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
# Optional: read token for previewing drafts (server-only, do NOT prefix NEXT_PUBLIC)
SANITY_API_READ_TOKEN=

# ---------------------------------------------------------------------------
# Site
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
